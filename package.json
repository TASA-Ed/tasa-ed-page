    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
