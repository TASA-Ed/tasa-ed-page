    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
