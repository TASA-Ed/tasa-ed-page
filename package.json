    "@types/node": "^25.5.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
