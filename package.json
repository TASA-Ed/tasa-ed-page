    "@types/node": "^25.4.0",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "svelte": "^5.53.9",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@^7.3.1"
